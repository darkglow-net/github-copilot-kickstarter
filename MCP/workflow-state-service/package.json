{
  "name": "workflow-state-service",
  "version": "0.1.0",
  "description": "MCP server for workflow state management with SQLite persistence",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --watch src/server.ts",
    "test": "node --no-warnings --test test/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0",
    "better-sqlite3": "^12.6.2",
    "kysely": "^0.28.11",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
